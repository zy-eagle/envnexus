# ===== Database =====
ENX_DATABASE_DSN=root:root@tcp(mysql:3306)/envnexus?charset=utf8mb4&parseTime=True&loc=Local

# ===== Redis =====
ENX_REDIS_ADDR=redis:6379
ENX_REDIS_PASSWORD=

# ===== Object Storage (MinIO) =====
ENX_OBJECT_STORAGE_ENDPOINT=minio:9000
ENX_OBJECT_STORAGE_BUCKET=envnexus
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ===== Security & Secrets =====
ENX_JWT_SECRET=replace_me_with_a_secure_random_string
ENX_DEVICE_TOKEN_SECRET=replace_me_with_a_secure_random_string
ENX_SESSION_TOKEN_SECRET=replace_me_with_a_secure_random_string

# ===== MySQL =====
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=envnexus

# ===== Platform API =====
ENX_HTTP_PORT=8080

# ===== Session Gateway (internal) =====
ENX_GATEWAY_URL=http://session-gateway:8081
ENX_SESSION_GATEWAY_PORT=8081

# ===== Job Runner =====
ENX_HEALTH_PORT=8082

# ===== Console Web =====
ENX_CONSOLE_PORT=3000

# ===== Agent Core LLM Providers =====
# Primary provider (openai | openrouter | ollama)
ENX_LLM_PRIMARY=ollama
ENX_OLLAMA_URL=http://localhost:11434
ENX_OLLAMA_MODEL=llama3.2
