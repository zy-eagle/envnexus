# ============================================================
#  EnvNexus — Environment Configuration
#
#  For one-click deployment, run:  ./deploy.sh start
#  The script auto-generates .env with secure secrets and
#  auto-detected host IP. You do NOT need to edit this file.
#
#  Only edit .env manually if you need custom configuration.
# ============================================================

# ===== Database =====
ENX_DATABASE_DSN=root:YOUR_MYSQL_PASSWORD@tcp(mysql:3306)/envnexus?charset=utf8mb4&parseTime=True&loc=Local
MYSQL_ROOT_PASSWORD=YOUR_MYSQL_PASSWORD
MYSQL_DATABASE=envnexus

# ===== Redis =====
ENX_REDIS_ADDR=redis:6379
ENX_REDIS_PASSWORD=

# ===== Object Storage (MinIO) =====
ENX_OBJECT_STORAGE_ENDPOINT=minio:9000
ENX_OBJECT_STORAGE_PUBLIC_ENDPOINT=YOUR_HOST_IP:9000
ENX_OBJECT_STORAGE_BUCKET=envnexus
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ===== Security & Secrets (auto-generated by deploy.sh) =====
ENX_JWT_SECRET=WILL_BE_AUTO_GENERATED
ENX_DEVICE_TOKEN_SECRET=WILL_BE_AUTO_GENERATED
ENX_SESSION_TOKEN_SECRET=WILL_BE_AUTO_GENERATED

# ===== Platform API =====
ENX_PLATFORM_API_HOST=0.0.0.0
ENX_PLATFORM_API_PORT=8080
ENX_HTTP_PORT=8080
ENX_PLATFORM_API_PUBLIC_BASE_URL=http://YOUR_HOST_IP:8080
ENX_CORS_ALLOWED_ORIGINS=http://YOUR_HOST_IP:3000,http://localhost:3000
ENX_GATEWAY_URL=http://session-gateway:8081

# ===== Session Gateway =====
ENX_SESSION_GATEWAY_HOST=0.0.0.0
ENX_SESSION_GATEWAY_PORT=8081
ENX_SESSION_GATEWAY_PUBLIC_WS_URL=ws://YOUR_HOST_IP:8081

# ===== Job Runner =====
ENX_HEALTH_PORT=8082
ENX_PLATFORM_URL=http://platform-api:8080
ENX_WS_URL=ws://session-gateway:8081/ws/v1/sessions

# ===== Console Web =====
ENX_CONSOLE_PORT=3000
ENX_CONSOLE_WEB_API_URL=http://platform-api:8080

# ===== Agent Core LLM Providers =====
# Primary provider (openai | openrouter | ollama)
# ENX_LLM_PRIMARY=ollama
# ENX_OLLAMA_URL=http://localhost:11434
# ENX_OLLAMA_MODEL=llama3.2
# ENX_OPENAI_API_KEY=
# ENX_OPENAI_BASE_URL=https://api.openai.com/v1
# ENX_OPENAI_MODEL=gpt-4o-mini
# ENX_OPENROUTER_API_KEY=
# ENX_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# ENX_OPENROUTER_MODEL=
# ENX_DEEPSEEK_API_KEY=
# ENX_DEEPSEEK_BASE_URL=https://api.deepseek.com
# ENX_DEEPSEEK_MODEL=deepseek-chat
# ENX_ANTHROPIC_API_KEY=
# ENX_ANTHROPIC_BASE_URL=https://api.anthropic.com
