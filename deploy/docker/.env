# Database
ENX_DATABASE_DSN=root:root@tcp(mysql:3306)/envnexus?charset=utf8mb4&parseTime=True&loc=Local

# Redis
ENX_REDIS_ADDR=redis:6379

# Object Storage (MinIO)
ENX_OBJECT_STORAGE_ENDPOINT=minio:9000
ENX_OBJECT_STORAGE_BUCKET=envnexus
ENX_MINIO_ROOT_USER=minioadmin
ENX_MINIO_ROOT_PASSWORD=minioadmin

# Security & Secrets
ENX_JWT_SECRET=replace_me_with_a_secure_random_string
ENX_DEVICE_TOKEN_SECRET=replace_me_with_a_secure_random_string
ENX_ENROLL_SIGNING_SECRET=replace_me_with_a_secure_random_string
ENX_INTERNAL_TOKEN=replace_me_with_a_secure_internal_token

# Platform API
ENX_PLATFORM_API_HOST=0.0.0.0
ENX_PLATFORM_API_PORT=8080
ENX_PLATFORM_API_PUBLIC_BASE_URL=http://localhost:8080

# Session Gateway
ENX_SESSION_GATEWAY_HOST=0.0.0.0
ENX_SESSION_GATEWAY_PORT=8081
ENX_SESSION_GATEWAY_PUBLIC_WS_URL=ws://localhost:8081

# Console Web
ENX_CONSOLE_WEB_API_URL=http://localhost:8080
