{
  "name": "envnexus-sync",
  "displayName": "EnvNexus Sync",
  "publisher": "zy-eagle",
  "version": "0.1.0",
  "description": "Sync with EnvNexus from Visual Studio Code.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/zy-eagle/envnexus.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onCommand:envnexus.login",
    "onCommand:envnexus.sync"
  ],
  "contributes": {
    "commands": [
      {
        "command": "envnexus.login",
        "title": "EnvNexus: Login"
      },
      {
        "command": "envnexus.sync",
        "title": "EnvNexus: Sync"
      }
    ]
  },
  "scripts": {
    "compile": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "vscode:prepublish": "webpack --mode production --devtool hidden-source-map",
    "package": "vsce package"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/node-fetch": "^2.6.11",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.2.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.5.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
}
